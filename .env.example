# --- Spine (preview/dev only — NEVER set these in the Vercel Production environment) ---

# Neon Postgres (Vercel Marketplace). Local dev: use a Neon branch database.
DATABASE_URL=

# Vercel AI Gateway key (synthesis, triage/verifier, embeddings)
AI_GATEWAY_API_KEY=

# Langfuse trace backend (https://cloud.langfuse.com). Tracing is a no-op when unset.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# demo (default) = scripted lib/demo-data.ts; graph = read the real spine.
# Leave unset in production: prod must behave identically to main.
DATA_MODE=

# debug in dev/preview for verbose pipeline logging
LOG_LEVEL=
